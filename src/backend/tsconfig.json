{
  "compilerOptions": {
    "target": "es2021",
    "module": "NodeNext",
    "rootDir": "./",
    "outDir": "../../dist/backend",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true
  },
  "include": [
    "**/*.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}
